# Copy this file to .env for local development.
# On Render, set these in the Environment Variables dashboard (do NOT commit .env to git).

# A long random secret used to sign JWTs. Generate one at: https://generate-secret.vercel.app/32
JWT_SECRET=change-me-to-a-long-random-secret

# Set to 'production' on Render.
NODE_ENV=production

# Render sets PORT automatically — you do not need to set this manually on Render.
# PORT=3001
