{
  "name": "quickdrop",
  "version": "1.0.0",
  "description": "QuickDrop — instant file transfer service",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && node src/server.js",
    "dev:frontend": "cd frontend && npx vite --port 5000 --host"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "axios": "^1.16.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "concurrently": "^8.2.2",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-dropzone": "^15.0.0",
    "react-router-dom": "^7.14.2",
    "uuid": "^14.0.0",
    "vite": "^8.0.10"
  }
}
